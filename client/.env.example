# MongoDB
MONGODB_URI=mongodb://localhost:27017/flova-ai
# or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/flova-ai

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=flova-ai-media
AWS_S3_ENDPOINT=https://s3.amazonaws.com

# Google AI
GEMINI_API_KEY=your-gemini-api-key
# Comma-separated list for rotation
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL_TEXT_ANALYSIS=gemini-3-flash-preview
GEMINI_MODEL_IMAGE_GENERATION=gemini-2.5-flash-image
GEMINI_MODEL_VIDEO_GENERATION=veo-3.1-fast-generate-preview
GEMINI_MODEL_TTS=lyria-002

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@flova.ai
SMTP_FROM_NAME=AntFlow

# YouTube OAuth
YOUTUBE_CLIENT_ID=your-youtube-oauth-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-oauth-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# Application
BASE_URL=http://localhost:3000
NODE_ENV=development
